generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  users        User[]
  customers    Customer[]
  collaterals  Collateral[]
  mortgages    Mortgage[]
  loans        Loan[]
  loanSchedules LoanSchedule[]
  payments     Payment[]
  settings     Setting[]

  @@map("organizations")
}

model User {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  username       String       @unique
  passwordHash   String
  name           String
  role           String       @default("STAFF") // ADMIN, STAFF
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("users")
}

model Customer {
  id             String       @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  customerNumber String       // C-NNNN 자동생성
  name           String
  customerType   String       @default("INDIVIDUAL") // INDIVIDUAL, CORPORATE
  residentNumber String?      // 암호화 저장
  businessNumber String?
  phone          String
  email          String?
  address        String?
  detailAddress  String?
  memo           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  collaterals    Collateral[]
  loans          Loan[]

  @@unique([organizationId, customerNumber])
  @@map("customers")
}

model Collateral {
  id              String     @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  customerId      String
  customer        Customer   @relation(fields: [customerId], references: [id])
  collateralType  String     // APARTMENT, HOUSE, LAND, BUILDING, OFFICETEL, OTHER
  address         String
  detailAddress   String?
  area            Decimal    @db.Decimal(10, 2) // 면적 (m²)
  appraisalValue  Decimal    @db.Decimal(15, 0) // 감정가
  memo            String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  mortgages       Mortgage[]
  loans           Loan[]

  @@map("collaterals")
}

model Mortgage {
  id              String     @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  collateralId    String
  collateral      Collateral @relation(fields: [collateralId], references: [id])
  rank            Int        // 순위
  mortgageType    String     // SENIOR(갑구), JUNIOR(을구)
  creditor        String     // 채권자
  maxClaimAmount  Decimal    @db.Decimal(15, 0) // 채권최고액
  loanAmount      Decimal?   @db.Decimal(15, 0) // 실 대출금
  memo            String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@map("mortgages")
}

model Loan {
  id              String         @id @default(cuid())
  organizationId  String?
  organization    Organization?  @relation(fields: [organizationId], references: [id])
  loanNumber      String         // YYYYMMDD-NNNN
  customerId      String
  customer        Customer       @relation(fields: [customerId], references: [id])
  collateralId    String?
  collateral      Collateral?    @relation(fields: [collateralId], references: [id])
  loanAmount      Decimal        @db.Decimal(15, 0) // 대출금액
  balance         Decimal        @db.Decimal(15, 0) // 대출잔액
  interestRate    Decimal        @db.Decimal(5, 2) // 연이율 (%)
  repaymentType   String         // BULLET, EQUAL_PRINCIPAL, EQUAL_PAYMENT
  loanTermMonths  Int            // 대출기간 (개월)
  startDate       DateTime       @db.Date
  endDate         DateTime       @db.Date
  status          String         @default("ACTIVE") // PENDING, ACTIVE, COMPLETED, OVERDUE, DEFAULT
  overdueStage    String         @default("NORMAL") // NORMAL, STAGE_1, STAGE_2, STAGE_3, BAD_DEBT
  overdueDays     Int            @default(0)
  memo            String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  schedules       LoanSchedule[]
  payments        Payment[]

  @@unique([organizationId, loanNumber])
  @@map("loans")
}

model LoanSchedule {
  id                String    @id @default(cuid())
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id])
  loanId            String
  loan              Loan      @relation(fields: [loanId], references: [id], onDelete: Cascade)
  installmentNumber Int       // 회차
  dueDate           DateTime  @db.Date
  principalAmount   Decimal   @db.Decimal(15, 0) // 원금
  interestAmount    Decimal   @db.Decimal(15, 0) // 이자
  totalAmount       Decimal   @db.Decimal(15, 0) // 합계
  remainingBalance  Decimal   @db.Decimal(15, 0) // 잔액
  status            String    @default("SCHEDULED") // SCHEDULED, PAID, OVERDUE, PARTIAL
  paidAmount        Decimal   @default(0) @db.Decimal(15, 0)
  paidDate          DateTime? @db.Date
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@map("loan_schedules")
}

model Payment {
  id              String   @id @default(cuid())
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  loanId          String
  loan            Loan     @relation(fields: [loanId], references: [id])
  paymentDate     DateTime @db.Date
  principalAmount Decimal  @db.Decimal(15, 0) // 원금
  interestAmount  Decimal  @db.Decimal(15, 0) // 이자
  overdueAmount   Decimal  @default(0) @db.Decimal(15, 0) // 연체이자
  totalAmount     Decimal  @db.Decimal(15, 0) // 합계
  memo            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("payments")
}

model Setting {
  id             String  @id @default(cuid())
  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  key            String
  value          String
  label          String?

  @@unique([organizationId, key])
  @@map("settings")
}
